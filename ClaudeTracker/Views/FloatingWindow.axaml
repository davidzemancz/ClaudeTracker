<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:ClaudeTracker.Converters"
        x:Class="ClaudeTracker.Views.FloatingWindow"
        Title="Claude Tracker"
        Width="260" SizeToContent="Height"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent" Topmost="True"
        CanResize="False" ShowInTaskbar="False">
    <Window.Resources>
        <conv:PercentToWidthConverter x:Key="PercentToWidth" />
        <conv:PercentToColorConverter x:Key="PercentToColor" />
    </Window.Resources>

    <Border Background="#DD1E1E2E" CornerRadius="10"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
            Padding="12,8">
        <StackPanel>
            <!-- Header -->
            <Grid Margin="0,0,0,6">
                <TextBlock Text="Claude" Foreground="{StaticResource AccentBrush}"
                           FontSize="12" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal" Margin="0,0,6,0">
                        <Ellipse Width="6" Height="6" Fill="{StaticResource GreenBrush}"
                                 VerticalAlignment="Center" Margin="0,0,3,0" />
                        <TextBlock Text="{Binding ActiveSessions}"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <Button Content="X" Command="{Binding CloseCommand}"
                            Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}"
                            BorderThickness="0" FontSize="10" Cursor="Hand"
                            Padding="4,0" />
                </StackPanel>
            </Grid>

            <!-- 5h bar -->
            <Grid Margin="0,0,0,4" ColumnDefinitions="24,*,36,36">
                <TextBlock Grid.Column="0" Text="5h" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="10" VerticalAlignment="Center" />
                <Border Grid.Column="1" Background="{StaticResource BarTrackBrush}"
                        CornerRadius="3" Height="10" Margin="0,0,6,0">
                    <Border CornerRadius="3" HorizontalAlignment="Left"
                            Background="{Binding FiveHourPercent, Converter={StaticResource PercentToColor}}"
                            Width="{Binding FiveHourPercent, Converter={StaticResource PercentToWidth}, ConverterParameter=130}" />
                </Border>
                <TextBlock Grid.Column="2" Text="{Binding FiveHourPercent, StringFormat={}{0:F0}%}"
                           Foreground="{StaticResource TextPrimaryBrush}" FontSize="10"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="3" Text="{Binding FiveHourResetText}"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="9"
                           VerticalAlignment="Center" HorizontalAlignment="Right" />
            </Grid>

            <!-- 7d bar -->
            <Grid ColumnDefinitions="24,*,36,36">
                <TextBlock Grid.Column="0" Text="7d" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="10" VerticalAlignment="Center" />
                <Border Grid.Column="1" Background="{StaticResource BarTrackBrush}"
                        CornerRadius="3" Height="10" Margin="0,0,6,0">
                    <Border CornerRadius="3" HorizontalAlignment="Left"
                            Background="{Binding SevenDayPercent, Converter={StaticResource PercentToColor}}"
                            Width="{Binding SevenDayPercent, Converter={StaticResource PercentToWidth}, ConverterParameter=130}" />
                </Border>
                <TextBlock Grid.Column="2" Text="{Binding SevenDayPercent, StringFormat={}{0:F0}%}"
                           Foreground="{StaticResource TextPrimaryBrush}" FontSize="10"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="3" Text=""
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="9"
                           VerticalAlignment="Center" HorizontalAlignment="Right" />
            </Grid>
        </StackPanel>
    </Border>
</Window>
