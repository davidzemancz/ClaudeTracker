<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ClaudeTracker.Converters"
             x:Class="ClaudeTracker.Views.TrayPopup">
    <UserControl.Resources>
        <conv:PercentToWidthConverter x:Key="PercentToWidth" />
        <conv:PercentToColorConverter x:Key="PercentToColor" />
        <conv:StringToVisibilityConverter x:Key="StringToVisibility" />
    </UserControl.Resources>

    <Border Background="{StaticResource BackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1" CornerRadius="8"
            Width="340" Padding="16">
        <StackPanel>
            <!-- Header -->
            <TextBlock Text="Claude Code Usage"
                       Foreground="{StaticResource AccentBrush}"
                       FontSize="16" FontWeight="SemiBold"
                       Margin="0,0,0,12" />

            <!-- 5-Hour Window -->
            <TextBlock Text="5-HOUR WINDOW"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="10" FontWeight="SemiBold"
                       Margin="0,0,0,4" />
            <Grid Margin="0,0,0,2" ColumnDefinitions="*,Auto">
                <!-- Progress bar -->
                <Border Grid.Column="0" Background="{StaticResource BarTrackBrush}"
                        CornerRadius="4" Height="14" Margin="0,0,8,0">
                    <Border CornerRadius="4" HorizontalAlignment="Left"
                            Background="{Binding FiveHourPercent, Converter={StaticResource PercentToColor}}"
                            Width="{Binding FiveHourPercent, Converter={StaticResource PercentToWidth}, ConverterParameter=260}" />
                </Border>
                <TextBlock Grid.Column="1"
                           Text="{Binding FiveHourPercent, StringFormat={}{0:F0}%}"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="12" FontWeight="Bold" VerticalAlignment="Center" Width="36" />
            </Grid>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Resets in " Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" />
                <TextBlock Text="{Binding FiveHourResetText}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" />
            </StackPanel>

            <!-- 7-Day Window -->
            <TextBlock Text="WEEKLY (7-DAY)"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="10" FontWeight="SemiBold"
                       Margin="0,0,0,4" />
            <Grid Margin="0,0,0,2" ColumnDefinitions="*,Auto">
                <Border Grid.Column="0" Background="{StaticResource BarTrackBrush}"
                        CornerRadius="4" Height="14" Margin="0,0,8,0">
                    <Border CornerRadius="4" HorizontalAlignment="Left"
                            Background="{Binding SevenDayPercent, Converter={StaticResource PercentToColor}}"
                            Width="{Binding SevenDayPercent, Converter={StaticResource PercentToWidth}, ConverterParameter=260}" />
                </Border>
                <TextBlock Grid.Column="1"
                           Text="{Binding SevenDayPercent, StringFormat={}{0:F0}%}"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="12" FontWeight="Bold" VerticalAlignment="Center" Width="36" />
            </Grid>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Resets in " Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" />
                <TextBlock Text="{Binding SevenDayResetText}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" />
            </StackPanel>

            <!-- Separator -->
            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,2,0,10" />

            <!-- Active Sessions -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Ellipse Width="8" Height="8" Fill="{StaticResource GreenBrush}"
                         VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBlock Foreground="{StaticResource TextPrimaryBrush}" FontSize="12">
                    <Run Text="{Binding ActiveSessions}" />
                    <Run Text=" active sessions" />
                </TextBlock>
            </StackPanel>

            <!-- Error text -->
            <TextBlock Text="{Binding ErrorText}"
                       Foreground="{StaticResource RedBrush}"
                       FontSize="9" Margin="0,0,0,4"
                       IsVisible="{Binding ErrorText, Converter={StaticResource StringToVisibility}}" />

            <!-- Last update -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Updated: " Foreground="{StaticResource TextSecondaryBrush}" FontSize="9" />
                <TextBlock Text="{Binding LastUpdateText}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="9" />
            </StackPanel>

            <!-- Buttons -->
            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">
                <Button Grid.Column="0" Content="Float" Command="{Binding FloatCommand}"
                        Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                        BorderBrush="{StaticResource BorderBrush}" Padding="12,4" Cursor="Hand" Margin="0,0,6,0" />

                <CheckBox Grid.Column="1" Content="Autostart"
                          IsChecked="{Binding StartWithWindows}"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          VerticalAlignment="Center" FontSize="10" />

                <Button Grid.Column="3" Content="Refresh" Command="{Binding RefreshCommand}"
                        Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                        BorderBrush="{StaticResource BorderBrush}" Padding="12,4" Cursor="Hand" Margin="0,0,6,0" />

                <Button Grid.Column="4" Content="Exit" Command="{Binding ExitCommand}"
                        Background="#442222" Foreground="{StaticResource TextPrimaryBrush}"
                        BorderBrush="{StaticResource BorderBrush}" Padding="12,4" Cursor="Hand" />
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
